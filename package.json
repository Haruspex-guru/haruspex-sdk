{
  "name": "haruspex-sdk-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Workspace root for the Haruspex SDK monorepo. The published packages live under packages/.",
  "license": "MIT",
  "scripts": {
    "build": "pnpm --filter \"@haruspex-guru-sdk/*\" build",
    "test": "pnpm --filter \"@haruspex-guru-sdk/*\" test",
    "lint": "pnpm --filter \"@haruspex-guru-sdk/*\" lint"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "msw"]
  }
}
